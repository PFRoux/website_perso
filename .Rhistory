facet_wrap(~Resolution) +  scale_fill_viridis_c(trans = "log") +
theme
# Correlation
spear_cor <- by(data_cor, INDICES =  data_cor$Resolution, FUN = function(x) {
cor <- cor(x$WGS,x$ATAC, use = "complete.obs", method = "spearman")
return(cor)
}, simplify = TRUE)
spear_cor <- data.frame(c(spear_cor),  c(1, 5, 10, 15, 30, 50, 100, 500, 1000))
colnames(spear_cor) <- c("Correlation", "Resolution")
